# ======================
# MemoryThread 生产环境配置
# ======================
# 使用方法：
#   1. 复制此文件：cp .env.production.example .env.production
#   2. 修改所有 CHANGE_ME 为实际值
#   3. 生成 SECRET_KEY：python3 -c "import secrets; print(secrets.token_urlsafe(32))"

# 环境标识
ENVIRONMENT=production

# 数据库配置
DB_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=mysql+pymysql://root:CHANGE_ME_STRONG_PASSWORD@db:3306/memory_thread

# JWT 配置（必须修改！）
SECRET_KEY=CHANGE_ME_RANDOM_STRING_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 管理员账号配置
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
ADMIN_EMAIL=admin@moondrift.cloud

# 文件上传配置
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# CORS 配置
CORS_ORIGINS=["https://moondrift.cloud","https://www.moondrift.cloud"]
